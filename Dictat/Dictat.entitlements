<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Nessun App Sandbox: serve il CGEvent tap globale (push-to-talk) e il post
      di Cmd+V via CGEvent. Hardened runtime ON nel target Release (notarizzazione).
    -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
